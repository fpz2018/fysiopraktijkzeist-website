{% extends "base.njk" %}

{% block title %}{{ title }} | {{ general.name }}{% endblock %}
{% block description %}{{ excerpt }}{% endblock %}

{% block head_extra %}
  {% if schema %}
  <script type="application/ld+json">{{ schema | safe }}</script>
  {% endif %}
  {% if faq_schema %}
  <script type="application/ld+json">{{ faq_schema | safe }}</script>
  {% endif %}
{% endblock %}

{% block page_styles %}
  <style>
    /* Dienst layout */
    .post-hero { background: var(--teal); padding: 56px 0 48px; }
    .post-breadcrumb { font-size: .8rem; color: rgba(255,255,255,.6); margin-bottom: 16px; }
    .post-breadcrumb a { color: rgba(255,255,255,.6); }
    .post-breadcrumb a:hover { color: #fff; }
    .post-category { display: inline-block; font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #7FD1DE; margin-bottom: 14px; }
    .post-hero h1 { font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 700; color: #fff; line-height: 1.2; max-width: 680px; margin-bottom: 16px; }
    .post-meta { font-size: .85rem; color: rgba(255,255,255,.6); display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
    .post-layout { display: grid; grid-template-columns: 1fr 300px; gap: 48px; align-items: start; padding: 56px 0 80px; }
    .post-body { background: #fff; border-radius: var(--radius); padding: 40px 48px; box-shadow: var(--shadow); }
    .post-body h2 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 700; color: var(--dark); margin: 32px 0 12px; }
    .post-body h2:first-child { margin-top: 0; }
    .post-body h3 { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 600; color: var(--dark); margin: 24px 0 10px; }
    .post-body p { font-size: 1rem; color: var(--dark); line-height: 1.8; margin-bottom: 18px; }
    .post-body ul, .post-body ol { padding-left: 24px; margin-bottom: 18px; }
    .post-body li { font-size: 1rem; line-height: 1.8; color: var(--dark); margin-bottom: 6px; }
    .post-body img { border-radius: 8px; margin: 24px 0; width: 100%; }
    .post-body a { color: var(--teal); text-decoration: underline; }
    .post-body strong { font-weight: 600; }
    .post-sidebar { display: flex; flex-direction: column; gap: 24px; position: sticky; top: 88px; max-height: calc(100dvh - 108px); overflow-y: auto; }
    .sidebar-card { background: #fff; border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); }
    .sidebar-card h3 { font-family: var(--font-serif); font-size: 1rem; font-weight: 600; color: var(--dark); margin-bottom: 12px; }
    .sidebar-card p { font-size: .875rem; color: var(--gray); line-height: 1.6; margin-bottom: 16px; }
    .mobile-cta-bar { display: none; }
    @media (max-width: 900px) {
      .post-layout { grid-template-columns: 1fr; }
      .post-sidebar { display: none; }
      .fab { display: none; }
      .mobile-cta-bar { display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: var(--z-fab); background: #fff; border-top: 1px solid var(--gray-light); padding: 12px 16px; gap: 10px; box-shadow: 0 -4px 20px rgba(0,0,0,.10); }
      .mobile-cta-bar a { flex: 1; justify-content: center; padding: 13px 10px; font-size: .9rem; }
      body { padding-bottom: 80px; }
    }
    @media (max-width: 600px) { .post-body { padding: 24px 20px; } }
  </style>
{% endblock %}

{% block content %}
<!-- Dienst header -->
<section class="post-hero">
  <div class="container">
    <p class="post-breadcrumb"><a href="/">Home</a> › <a href="/#behandelingen">Behandelingen</a> › {{ title }}</p>
    {% if category %}<span class="post-category">{{ category }}</span>{% endif %}
    <h1>{{ title }}</h1>
  </div>
</section>

<!-- Dienst inhoud -->
<div class="container">
  <div class="post-layout">
    <article class="post-body">
      {{ content | safe }}
    </article>
    <aside class="post-sidebar">
      <div class="sidebar-card">
        <h3>📅 Afspraak maken</h3>
        <p>Interesse in deze behandeling? Maak direct een afspraak — geen verwijzing nodig.</p>
        <a href="/#afspraak" class="btn btn-primary" style="width:100%;justify-content:center">Afspraak maken</a>
      </div>
      <div class="sidebar-card">
        <h3>💬 Snel contact</h3>
        <p>Liever eerst overleggen? App of bel ons direct.</p>
        <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-outline" style="width:100%;justify-content:center;margin-bottom:10px">WhatsApp</a>
        <a href="tel:{{ general.phone }}" style="display:block;text-align:center;font-size:.875rem;color:var(--teal)">📞 {{ general.phone }}</a>
      </div>
      <div class="sidebar-card" style="background:var(--teal-pale);border:1px solid rgba(27,94,107,.12)">
        <h3>⭐ {{ general.review_score }}/10</h3>
        <p>{{ general.review_count }} patiënten beoordeelden ons op ZorgkaartNederland.</p>
      </div>
    </aside>
  </div>
</div>
{% endblock %}

{% block body_end %}
<div class="mobile-cta-bar">
  <a href="/#afspraak" class="btn btn-primary">📅 Afspraak maken</a>
  <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-outline">💬 WhatsApp</a>
</div>
{% endblock %}
