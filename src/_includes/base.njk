<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}{{ title }}{% endblock %}</title>
  {% set _desc = description or general.default_description %}
  <meta name="description" content="{% block description %}{{ _desc }}{% endblock %}" />

  {# Canonical URL #}
  {% set _siteUrl = (general.site_url or 'https://fysiopraktijkzeist.nl') | stripTrailingSlash %}
  {% set _canonical = _siteUrl + page.url %}
  <link rel="canonical" href="{{ _canonical }}" />

  {# Open Graph (Facebook, WhatsApp, LinkedIn) #}
  <meta property="og:type" content="{% block og_type %}website{% endblock %}" />
  <meta property="og:locale" content="nl_NL" />
  <meta property="og:site_name" content="{{ general.name }}" />
  <meta property="og:title" content="{% block og_title %}{{ title }}{% endblock %}" />
  <meta property="og:description" content="{% block og_description %}{{ _desc }}{% endblock %}" />
  <meta property="og:url" content="{{ _canonical }}" />
  {% set _ogImg = ogImage or general.og_image %}
  {% if _ogImg %}<meta property="og:image" content="{{ _siteUrl }}{{ _ogImg }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />{% endif %}

  {# Twitter Cards #}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{% block tw_title %}{{ title }}{% endblock %}" />
  <meta name="twitter:description" content="{% block tw_description %}{{ _desc }}{% endblock %}" />
  {% if _ogImg %}<meta name="twitter:image" content="{{ _siteUrl }}{{ _ogImg }}" />{% endif %}

  {# Favicon & PWA #}
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#1B5E6B" />

  {# Crawler-instructies #}
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <meta name="author" content="{{ general.name }}" />

  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Geist:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />

  {# ─────── Structured data: LocalBusiness (Physiotherapist) ─────── #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["MedicalBusiness", "Physiotherapist", "LocalBusiness"],
    "@id": "{{ _siteUrl }}/#praktijk",
    "name": {{ general.name | dump | safe }},
    "url": "{{ _siteUrl }}",
    "telephone": {{ general.phone | dump | safe }},
    "email": {{ general.email | dump | safe }},
    "image": "{{ _siteUrl }}{{ general.og_image }}",
    {% if general.logo_url %}"logo": "{{ _siteUrl }}{{ general.logo_url }}",{% endif %}
    "priceRange": {{ (general.price_range or "€€") | dump | safe }},
    "currenciesAccepted": "EUR",
    "paymentAccepted": "Cash, Credit Card, iDEAL, Invoice",
    {% if general.founding_year %}"foundingDate": {{ general.founding_year | dump | safe }},{% endif %}
    {% if general.kvk %}"vatID": "NL{{ general.kvk }}", "taxID": {{ general.kvk | dump | safe }},{% endif %}
    "address": {
      "@type": "PostalAddress",
      "streetAddress": {{ (general.address_street or general.address) | dump | safe }},
      "postalCode": {{ (general.address_postal or "") | dump | safe }},
      "addressLocality": {{ (general.address_city or "Zeist") | dump | safe }},
      "addressCountry": {{ (general.address_country or "NL") | dump | safe }}
    },
    {% if general.latitude and general.longitude %}"geo": {
      "@type": "GeoCoordinates",
      "latitude": {{ general.latitude | dump | safe }},
      "longitude": {{ general.longitude | dump | safe }}
    },{% endif %}
    "areaServed": [
      {% for place in general.service_areas %}{ "@type": "City", "name": {{ place | dump | safe }} }{% if not loop.last %},{% endif %}{% endfor %}
    ],
    "openingHoursSpecification": [
      {% for d in openingHours %}{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": {{ d.day | dump | safe }},
        "opens": {{ d.opens | dump | safe }},
        "closes": {{ d.closes | dump | safe }}
      }{% if not loop.last %},{% endif %}{% endfor %}
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ general.review_score | replace(',', '.') }}",
      "bestRating": "10",
      "worstRating": "1",
      "ratingCount": {{ general.review_count }},
      "reviewCount": {{ general.review_count }}
    },
    {% set _socials = [general.facebook_url, general.instagram_url, general.linkedin_url, general.zorgkaart_url, general.google_business_url] | compact %}
    "sameAs": [{% for url in _socials %}{{ url | dump | safe }}{% if not loop.last %},{% endif %}{% endfor %}],
    "medicalSpecialty": ["Physiotherapy", "PhysicalTherapy"],
    "availableService": [
      {% for s in services.items %}{
        "@type": "MedicalTherapy",
        "name": {{ s.name | dump | safe }},
        "url": "{{ _siteUrl }}{{ s.url }}"
      }{% if not loop.last %},{% endif %}{% endfor %}
    ]
  }
  </script>

  {# Person schema voor de eigenaar — versterkt E-E-A-T #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "{{ _siteUrl }}/#marc",
    "name": "Marc de Jong",
    "jobTitle": "Fysiotherapeut & orthomoleculair therapeut (kPNI)",
    "image": "{{ _siteUrl }}/images/uploads/marc_mg_0629.jpg",
    "worksFor": { "@id": "{{ _siteUrl }}/#praktijk" },
    "knowsAbout": ["Fysiotherapie", "Manuele therapie", "Diagnostische echografie", "Dry needling", "Orthomoleculaire therapie", "kPNI", "Valpreventie"]{% if general.big_owner %},
    "identifier": { "@type": "PropertyValue", "propertyID": "BIG-register", "value": {{ general.big_owner | dump | safe }} }{% endif %}
  }
  </script>
  <style>
    /* Sticky header wrapper (status-bar + nav samen) */
    .site-header { position: sticky; top: 0; z-index: var(--z-sticky); }
    .site-header .nav { position: static; }
    /* Status-bar (live open/gesloten) */
    .status-bar { background: var(--teal-pale); color: var(--gray); font-size: .8rem; font-weight: 500; line-height: 1; border-bottom: 1px solid rgba(27,94,107,.08); }
    .status-bar__inner { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 16px; padding: 8px 0; min-height: 28px; }
    .status-bar__status { display: inline-flex; align-items: center; gap: 8px; color: var(--dark); font-variant-numeric: tabular-nums; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .status-bar__status::before { content: '●'; color: #22C55E; font-size: .9rem; line-height: 1; animation: statusDot 2s ease-in-out infinite; }
    .status-bar--closed .status-bar__status::before { color: #EF4444; }
    @keyframes statusDot { 0%, 100% { opacity: 1; } 50% { opacity: .4; } }
    .status-bar__call { color: var(--teal); font-weight: 600; text-decoration: none; font-variant-numeric: tabular-nums; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; transition: color .15s; }
    .status-bar__call:hover { color: var(--teal-light); }

    /* Nieuwsticker (midden) */
    .status-bar__ticker { position: relative; min-height: 1em; text-align: center; color: var(--teal); font-weight: 600; overflow: hidden; }
    .status-bar__ticker-item { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .6s ease; padding: 0 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    /* Pre-JS: toon alleen het eerste item zodat de balk de juiste hoogte heeft */
    .status-bar__ticker-item:first-child { position: relative; opacity: 1; }
    /* JS-ready: alle items reset, alleen .is-active is zichtbaar */
    .status-bar__ticker.js-ready .status-bar__ticker-item { position: absolute; opacity: 0; }
    .status-bar__ticker.js-ready .status-bar__ticker-item.is-active { position: relative; opacity: 1; }

    @media (max-width: 760px) {
      .status-bar__inner { grid-template-columns: auto auto; grid-template-areas: "status call" "ticker ticker"; row-gap: 4px; padding: 7px 0; }
      .status-bar__status { grid-area: status; }
      .status-bar__call { grid-area: call; justify-self: end; }
      .status-bar__ticker { grid-area: ticker; text-align: left; padding-top: 2px; border-top: 1px solid rgba(27,94,107,.08); padding-top: 6px; margin-top: 2px; }
      .status-bar__ticker-item { white-space: normal; }
      .status-bar { font-size: .72rem; }
      .status-bar__call { font-size: .78rem; }
    }
    @media (prefers-reduced-motion: reduce) { .status-bar__status::before { animation: none; } .status-bar__ticker-item { transition: none; } }
  </style>
  {% block head_extra %}{% endblock %}
  {% block page_styles %}{% endblock %}
</head>
<body{% if body_class %} class="{{ body_class }}"{% endif %}>

{% block body_start %}{% endblock %}

{% block nav %}
<div class="site-header">
  {% set hasTicker = false %}
  {% if ticker.enabled and ticker.items %}
    {% for item in ticker.items %}{% if item.active and item.text %}{% set hasTicker = true %}{% endif %}{% endfor %}
  {% endif %}
  <div class="status-bar" id="navStatus" data-mon="{{ hours.monday }}" data-tue="{{ hours.tuesday }}" data-wed="{{ hours.wednesday }}" data-thu="{{ hours.thursday }}" data-fri="{{ hours.friday }}">
    <div class="container status-bar__inner">
      <span class="status-bar__status" id="navStatusLine">Nu open</span>
      {% if hasTicker %}
      <div class="status-bar__ticker" id="navTicker" data-interval="{{ ticker.interval_seconds or 5 }}" aria-live="polite">
        {% for item in ticker.items %}{% if item.active and item.text %}<span class="status-bar__ticker-item">{{ item.text }}</span>{% endif %}{% endfor %}
      </div>
      {% else %}
      <span></span>
      {% endif %}
      <a href="tel:{{ general.phone }}" class="status-bar__call">📞 {{ general.phone }}</a>
    </div>
  </div>
  <nav class="nav">
    <div class="container nav__inner">
      <a href="/" class="nav__logo">
        {{ general.name }}
        <span>Fysiotherapeut zonder verwijzing</span>
      </a>
      <ul class="nav__links">
        <li><a href="/#behandelingen">Behandelingen</a></li>
        <li><a href="/#afspraak">Afspraak maken</a></li>
        <li><a href="/#team">Team</a></li>
        <li><a href="/#blog">Blog</a></li>
        <li><a href="/shop">Shop</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
      <div class="nav__actions">
        <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="padding:10px 18px;font-size:.85rem">💬 Afspraak maken</a>
      </div>
      <button class="nav__hamburger" id="menuBtn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</div>

<div class="mobile-menu" id="mobileMenu">
  <a href="/#behandelingen" onclick="closeMobileMenu()">Behandelingen</a>
  <a href="/#afspraak" onclick="closeMobileMenu()">Afspraak maken</a>
  <a href="/#team" onclick="closeMobileMenu()">Team</a>
  <a href="/#blog" onclick="closeMobileMenu()">Blog</a>
  <a href="/shop" onclick="closeMobileMenu()">Shop</a>
  <a href="/#contact" onclick="closeMobileMenu()">Contact</a>
  <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="margin-top:8px">💬 WhatsApp afspraak</a>
  <a href="tel:{{ general.phone }}" class="btn btn-outline" style="margin-top:4px">📞 {{ general.phone }}</a>
</div>
{% endblock %}

{% block content %}{% endblock %}

{% block footer %}
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <div class="nav__logo">{{ general.name }}<span>Fysiotherapeut zonder verwijzing</span></div>
        <p>Wij behandelen de oorzaak van uw klacht — met persoonlijke aandacht en bewezen methoden. Al meer dan 35 jaar de fysiotherapiepraktijk van Zeist en omstreken.</p>
        <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap">
          <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="padding:10px 18px;font-size:.85rem">💬 WhatsApp</a>
          <a href="tel:{{ general.phone }}" style="padding:10px 18px;font-size:.85rem;display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.2);border-radius:50px">📞 {{ general.phone }}</a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Openingstijden</h4>
        <ul class="footer__hours">
          <li><span>Maandag</span><span>{{ hours.monday }}</span></li>
          <li><span>Dinsdag</span><span>{{ hours.tuesday }}</span></li>
          <li><span>Woensdag</span><span>{{ hours.wednesday }}</span></li>
          <li><span>Donderdag</span><span>{{ hours.thursday }}</span></li>
          <li><span>Vrijdag</span><span>{{ hours.friday }}</span></li>
          <li><span>Zat &amp; Zon</span><span>Gesloten</span></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <ul class="footer__links">
          <li>{{ general.address }}</li>
          <li style="margin-top:10px"><a href="tel:{{ general.phone }}">📞 {{ general.phone }}</a></li>
          <li><a href="https://wa.me/{{ general.whatsapp }}">💬 WhatsApp</a></li>
          <li><a href="mailto:{{ general.email }}">✉ {{ general.email }}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2026 {{ general.name }} — BIG-geregistreerd · {{ general.review_score }}/10 op ZorgkaartNederland</span>
      <div class="footer__legal">
        <a href="/veelgestelde-vragen">FAQ</a>
        <a href="/privacy">Privacy</a>
        <a href="/algemene-voorwaarden">Algemene voorwaarden</a>
        <a href="/betalingsvoorwaarden">Betalingsvoorwaarden</a>
        <a href="/tarieven">Tarieven 2026</a>
      </div>
    </div>
  </div>
</footer>
{% endblock %}

{% block fab %}
<a class="fab" href="https://wa.me/{{ general.whatsapp }}?text=Hallo%2C%20ik%20wil%20graag%20een%20afspraak%20maken" aria-label="WhatsApp">💬</a>
{% endblock %}

{% block body_end %}{% endblock %}

<script>
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  if (menuBtn) menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('open'));
  function closeMobileMenu() { if (mobileMenu) mobileMenu.classList.remove('open'); }
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on('init', user => {
      if (!user) { window.netlifyIdentity.on('login', () => { document.location.href = '/admin/'; }); }
    });
  }

  // Live open/gesloten status in header
  (function() {
    const wrap = document.getElementById('navStatus');
    const line = document.getElementById('navStatusLine');
    if (!wrap || !line) return;
    const dataKeys = ['', 'mon','tue','wed','thu','fri',''];
    const dayLabels = ['zondag','maandag','dinsdag','woensdag','donderdag','vrijdag','zaterdag'];
    const isMobile = () => window.matchMedia('(max-width: 600px)').matches;
    function parseRange(str) {
      if (!str) return null;
      const m = str.match(/(\d{1,2})[:.]?(\d{2})?\s*[-–]\s*(\d{1,2})[:.]?(\d{2})?/);
      if (!m) return null;
      return { open: parseInt(m[1],10)*60 + parseInt(m[2]||'0',10), close: parseInt(m[3],10)*60 + parseInt(m[4]||'0',10) };
    }
    function fmtTime(mins) { return `${Math.floor(mins/60)}:${String(mins%60).padStart(2,'0')}`; }
    function findNextOpen(day, mins) {
      for (let offset = 0; offset <= 7; offset++) {
        const d = (day + offset) % 7;
        const k = dataKeys[d];
        const r = k ? parseRange(wrap.dataset[k]) : null;
        if (!r) continue;
        if (offset === 0 && mins >= r.open) continue;
        const when = offset === 0 ? 'vandaag' : offset === 1 ? 'morgen' : dayLabels[d];
        return { when, time: fmtTime(r.open) };
      }
      return null;
    }
    function update() {
      const now = new Date();
      const day = now.getDay();
      const mins = now.getHours()*60 + now.getMinutes();
      const key = dataKeys[day];
      const range = key ? parseRange(wrap.dataset[key]) : null;
      const open = range && mins >= range.open && mins < range.close;
      if (open) {
        wrap.classList.remove('status-bar--closed');
        line.textContent = isMobile() ? `Nu open tot ${fmtTime(range.close)}` : `Nu open · sluit om ${fmtTime(range.close)}`;
      } else {
        wrap.classList.add('status-bar--closed');
        const next = findNextOpen(day, mins);
        if (next) {
          line.textContent = isMobile() ? `Gesloten · open ${next.when} ${next.time}` : `Nu gesloten · opent ${next.when} om ${next.time}`;
        } else {
          line.textContent = 'Nu gesloten';
        }
      }
    }
    update();
    setInterval(update, 60000);
    window.addEventListener('resize', update);
  })();

  // Nieuwsticker fade-cyclus
  (function() {
    const ticker = document.getElementById('navTicker');
    if (!ticker) return;
    const items = ticker.querySelectorAll('.status-bar__ticker-item');
    if (!items.length) return;
    items[0].classList.add('is-active');
    ticker.classList.add('js-ready');
    if (items.length < 2) return;
    const interval = Math.max(2, parseInt(ticker.dataset.interval, 10) || 5) * 1000;
    let i = 0;
    setInterval(() => {
      items[i].classList.remove('is-active');
      i = (i + 1) % items.length;
      items[i].classList.add('is-active');
    }, interval);
  })();
</script>
</body>
</html>
