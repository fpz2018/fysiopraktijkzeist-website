---
title: Veelgestelde vragen | Fysiopraktijk Zeist
description: Antwoorden op de meestgestelde vragen over fysiotherapie, vergoedingen, verwijzingen en afspraken bij Fysiopraktijk Zeist.
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Geist:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />

  <!-- Schema.org FAQ markup voor Google -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for item in faq.items %}
      {
        "@type": "Question",
        "name": {{ item.question | dump }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ item.answer | dump }}
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>

  <style>
    /* Hero */
    .page-hero { background: var(--teal); padding: 56px 0 48px; }
    .page-hero h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; color: #fff; margin-bottom: 12px; }
    .page-hero p { font-size: 1.05rem; color: rgba(255,255,255,.8); max-width: 560px; line-height: 1.7; }
    .breadcrumb { font-size: .8rem; color: rgba(255,255,255,.55); margin-bottom: 16px; }
    .breadcrumb a { color: rgba(255,255,255,.55); }
    .breadcrumb a:hover { color: #fff; }
    /* FAQ */
    .faq-content { max-width: 780px; margin: 0 auto; padding: 64px 0 80px; }
    .faq-list { display: flex; flex-direction: column; gap: 12px; }
    details.faq-item { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; border: 1px solid transparent; transition: border-color .2s; }
    details.faq-item[open] { border-color: var(--teal-pale); }
    details.faq-item summary { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 24px; font-size: 1rem; font-weight: 600; color: var(--dark); cursor: pointer; list-style: none; user-select: none; }
    details.faq-item summary::-webkit-details-marker { display: none; }
    details.faq-item summary::after { content: '+'; font-size: 1.4rem; font-weight: 300; color: var(--teal); flex-shrink: 0; transition: transform .25s; line-height: 1; }
    details.faq-item[open] summary { color: var(--teal); border-bottom: 1px solid var(--gray-light); }
    details.faq-item[open] summary::after { transform: rotate(45deg); }
    details.faq-item summary:hover { background: var(--teal-pale); }
    .faq-answer { padding: 20px 24px 24px; }
    .faq-answer p { font-size: .95rem; color: var(--gray); line-height: 1.8; margin-bottom: 12px; }
    .faq-answer p:last-child { margin-bottom: 0; }
    .faq-answer ul, .faq-answer ol { margin: 8px 0 12px 0; display: flex; flex-direction: column; gap: 6px; list-style: none; padding: 0; }
    .faq-answer ul li, .faq-answer ol li { display: flex; align-items: flex-start; gap: 10px; font-size: .93rem; color: var(--dark); line-height: 1.6; }
    .faq-answer ul li::before { content: '–'; color: var(--teal); font-weight: 700; flex-shrink: 0; margin-top: 2px; }
    .faq-answer ol { counter-reset: faq-counter; }
    .faq-answer ol li { counter-increment: faq-counter; }
    .faq-answer ol li::before { content: counter(faq-counter); background: var(--teal-pale); color: var(--teal); font-size: .75rem; font-weight: 700; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .faq-answer strong { color: var(--dark); font-weight: 600; }
    .faq-answer a { color: var(--teal); text-decoration: underline; }
    .faq-cta { margin-top: 48px; background: linear-gradient(135deg, var(--teal) 0%, #0f3d47 100%); border-radius: var(--radius); padding: 36px 40px; text-align: center; }
    .faq-cta h2 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 700; color: #fff; margin-bottom: 10px; }
    .faq-cta p { color: rgba(255,255,255,.8); font-size: .95rem; margin-bottom: 24px; }
    .faq-cta .btn-group { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    @media (max-width: 900px) { .faq-cta { padding: 28px 24px; } }
  </style>
</head>
<body>

<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">
      {{ general.name }}
      <span>Fysiotherapeut zonder verwijzing</span>
    </a>
    <ul class="nav__links">
      <li><a href="/#behandelingen">Behandelingen</a></li>
      <li><a href="/#afspraak">Afspraak maken</a></li>
      <li><a href="/#team">Team</a></li>
      <li><a href="/#blog">Blog</a></li>
      <li><a href="/shop">Shop</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
    <div class="nav__actions">
      <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="padding:10px 18px;font-size:.85rem">💬 Afspraak maken</a>
    </div>
    <button class="nav__hamburger" id="menuBtn" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/#behandelingen" onclick="closeMobileMenu()">Behandelingen</a>
  <a href="/#afspraak" onclick="closeMobileMenu()">Afspraak maken</a>
  <a href="/#team" onclick="closeMobileMenu()">Team</a>
  <a href="/#blog" onclick="closeMobileMenu()">Blog</a>
  <a href="/shop" onclick="closeMobileMenu()">Shop</a>
  <a href="/#contact" onclick="closeMobileMenu()">Contact</a>
  <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="margin-top:8px">💬 WhatsApp afspraak</a>
  <a href="tel:{{ general.phone }}" class="btn btn-outline" style="margin-top:4px">📞 {{ general.phone }}</a>
</div>

<section class="page-hero">
  <div class="container">
    <p class="breadcrumb"><a href="/">Home</a> › Veelgestelde vragen</p>
    <h1>Veelgestelde vragen</h1>
    <p>Antwoorden op de meestgestelde vragen over fysiotherapie, vergoedingen, verwijzingen en afspraken.</p>
  </div>
</section>

<main>
  <div class="container">
    <div class="faq-content">

      <div class="faq-list">
        {% for item in faq.items %}
        <details class="faq-item">
          <summary>{{ item.question }}</summary>
          <div class="faq-answer">
            {{ item.answer | markdownify | safe }}
          </div>
        </details>
        {% endfor %}
      </div>

      <div class="faq-cta">
        <h2>Staat uw vraag er niet bij?</h2>
        <p>Neem gerust contact met ons op — we helpen u graag verder.</p>
        <div class="btn-group">
          <a href="tel:{{ general.phone }}" class="btn btn-primary">📞 {{ general.phone }}</a>
          <a href="https://wa.me/{{ general.whatsapp }}" class="btn" style="background:rgba(255,255,255,.15);color:#fff;border-color:rgba(255,255,255,.3)">💬 WhatsApp</a>
        </div>
      </div>

    </div>
  </div>
</main>

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <div class="nav__logo">{{ general.name }}<span>Fysiotherapeut zonder verwijzing</span></div>
        <p>Wij behandelen de oorzaak van uw klacht — met persoonlijke aandacht en bewezen methoden. Al meer dan 35 jaar de fysiotherapiepraktijk van Zeist en omstreken.</p>
        <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap">
          <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="padding:10px 18px;font-size:.85rem">💬 WhatsApp</a>
          <a href="tel:{{ general.phone }}" style="padding:10px 18px;font-size:.85rem;display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.2);border-radius:50px">📞 {{ general.phone }}</a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Openingstijden</h4>
        <ul class="footer__hours">
          <li><span>Maandag</span><span>{{ hours.monday }}</span></li>
          <li><span>Dinsdag</span><span>{{ hours.tuesday }}</span></li>
          <li><span>Woensdag</span><span>{{ hours.wednesday }}</span></li>
          <li><span>Donderdag</span><span>{{ hours.thursday }}</span></li>
          <li><span>Vrijdag</span><span>{{ hours.friday }}</span></li>
          <li><span>Zat &amp; Zon</span><span>Gesloten</span></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <ul class="footer__links">
          <li>{{ general.address }}</li>
          <li style="margin-top:10px"><a href="tel:{{ general.phone }}">📞 {{ general.phone }}</a></li>
          <li><a href="https://wa.me/{{ general.whatsapp }}">💬 WhatsApp</a></li>
          <li><a href="mailto:{{ general.email }}">✉ {{ general.email }}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2026 {{ general.name }} — BIG-geregistreerd · {{ general.review_score }}/10 op ZorgkaartNederland</span>
      <div class="footer__legal">
        <a href="/veelgestelde-vragen">FAQ</a>
        <a href="/privacy">Privacy</a>
        <a href="/algemene-voorwaarden">Algemene voorwaarden</a>
        <a href="/betalingsvoorwaarden">Betalingsvoorwaarden</a>
        <a href="/tarieven">Tarieven 2026</a>
      </div>
    </div>
  </div>
</footer>

<a class="fab" href="https://wa.me/{{ general.whatsapp }}?text=Hallo%2C%20ik%20wil%20graag%20een%20afspraak%20maken" aria-label="WhatsApp">💬</a>

<script>
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('open'));
  function closeMobileMenu() { mobileMenu.classList.remove('open'); }
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on('init', user => {
      if (!user) { window.netlifyIdentity.on('login', () => { document.location.href = '/admin/'; }); }
    });
  }
</script>
</body>
</html>
