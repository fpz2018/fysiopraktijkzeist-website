---
title: Fysiotherapeut in Zeist | Fysiopraktijk Zeist — Geen verwijzing nodig
description: Fysiotherapeut in Zeist zonder verwijzing. Manuele therapie, dry needling, echografie en meer. Gemiddeld binnen 3 dagen geholpen.
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,300&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal:#1B5E6B; --teal-light:#2A7F91; --teal-pale:#EBF5F7;
      --orange:#D96B2F; --orange-light:#F5834A; --cream:#F8F5EF;
      --dark:#1A2332; --gray:#5A6778; --gray-light:#E8E4DE;
      --radius:12px; --shadow:0 4px 24px rgba(27,94,107,.10);
      --shadow-lg:0 12px 48px rgba(27,94,107,.16);
      --font-serif:'Fraunces',Georgia,serif; --font-sans:'Inter',system-ui,sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-sans); background: var(--cream); color: var(--dark); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    .container { width: 100%; max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 50px; font-family: var(--font-sans); font-size: .95rem; font-weight: 600; cursor: pointer; border: 2px solid transparent; transition: all .2s ease; white-space: nowrap; text-decoration: none; }
    .btn-primary { background: var(--orange); color: #fff; border-color: var(--orange); }
    .btn-primary:hover { background: var(--orange-light); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(217,107,47,.35); color: #fff; }
    .btn-outline { background: transparent; color: var(--teal); border-color: var(--teal); }
    .btn-outline:hover { background: var(--teal); color: #fff; }
    .btn-white { background: #fff; color: var(--teal); border-color: #fff; }
    .btn-white:hover { background: var(--cream); }
    .btn-ghost { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.2); }
    .btn-ghost:hover { background: rgba(255,255,255,.2); color: #fff; }
    .btn-group { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
    .nav { position: sticky; top: 0; z-index: 100; background: rgba(248,245,239,.96); backdrop-filter: blur(12px); border-bottom: 1px solid var(--gray-light); }
    .nav__inner { display: flex; align-items: center; justify-content: space-between; height: 68px; }
    .nav__logo { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 700; color: var(--teal); line-height: 1.1; }
    .nav__logo span { display: block; font-size: .68rem; font-weight: 400; color: var(--gray); font-family: var(--font-sans); letter-spacing: .05em; text-transform: uppercase; }
    .nav__links { display: flex; gap: 4px; list-style: none; }
    .nav__links a { padding: 8px 14px; border-radius: 8px; font-size: .9rem; font-weight: 500; color: var(--dark); transition: background .15s, color .15s; }
    .nav__links a:hover { background: var(--teal-pale); color: var(--teal); }
    .nav__actions { display: flex; align-items: center; gap: 8px; }
    .nav__hamburger { display: none; background: none; border: none; cursor: pointer; padding: 8px; flex-direction: column; gap: 5px; }
    .nav__hamburger span { display: block; width: 22px; height: 2px; background: var(--dark); border-radius: 2px; }
    .mobile-menu { display: none; position: fixed; inset: 0; top: 68px; background: var(--cream); z-index: 99; padding: 24px; flex-direction: column; gap: 8px; overflow-y: auto; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { padding: 14px 16px; border-radius: var(--radius); font-size: 1rem; font-weight: 500; color: var(--dark); border: 1px solid var(--gray-light); background: #fff; }
    @media (max-width: 768px) { .nav__links, .nav__actions .btn { display: none; } .nav__hamburger { display: flex; } }
    .hero { background: var(--teal); padding: 80px 0 72px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,.06) 1px, transparent 1px); background-size: 28px 28px; pointer-events: none; }
    .hero::after { content: ''; position: absolute; bottom: -80px; right: -80px; width: 480px; height: 480px; background: radial-gradient(circle, rgba(217,107,47,.22) 0%, transparent 70%); pointer-events: none; }
    .hero__inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center; }
    .hero__badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2); border-radius: 50px; padding: 6px 14px; font-size: .8rem; font-weight: 500; color: rgba(255,255,255,.9); margin-bottom: 20px; }
    .hero__badge::before { content: '●'; font-size: .6rem; }

    /* Groen — ruim plek */
    .hero__badge--groen { animation: badgePulseGreen 3s ease-in-out infinite; }
    .hero__badge--groen::before { color: #4ADE80; animation: dotPulseGreen 2s ease-in-out infinite; }
    @keyframes badgePulseGreen {
      0%, 100% { box-shadow: 0 0 0 0 rgba(74,222,128,.0); }
      50% { box-shadow: 0 0 12px 4px rgba(74,222,128,.18), 0 0 24px rgba(74,222,128,.08); border-color: rgba(74,222,128,.35); }
    }
    @keyframes dotPulseGreen {
      0%, 100% { opacity: 1; text-shadow: 0 0 0 rgba(74,222,128,0); }
      50% { opacity: .6; text-shadow: 0 0 8px rgba(74,222,128,.8); }
    }

    /* Oranje — beperkt plek */
    .hero__badge--oranje { animation: badgePulseOrange 2.5s ease-in-out infinite; }
    .hero__badge--oranje::before { color: #FB923C; animation: dotPulseOrange 1.8s ease-in-out infinite; }
    @keyframes badgePulseOrange {
      0%, 100% { box-shadow: 0 0 0 0 rgba(251,146,60,.0); }
      50% { box-shadow: 0 0 14px 5px rgba(251,146,60,.22), 0 0 28px rgba(251,146,60,.10); border-color: rgba(251,146,60,.4); }
    }
    @keyframes dotPulseOrange {
      0%, 100% { opacity: 1; text-shadow: 0 0 0 rgba(251,146,60,0); }
      50% { opacity: .5; text-shadow: 0 0 10px rgba(251,146,60,.9); }
    }

    /* Rood — bijna vol */
    .hero__badge--rood { animation: badgePulseRed 2s ease-in-out infinite; }
    .hero__badge--rood::before { color: #F87171; animation: dotPulseRed 1.4s ease-in-out infinite; }
    @keyframes badgePulseRed {
      0%, 100% { box-shadow: 0 0 0 0 rgba(248,113,113,.0); }
      50% { box-shadow: 0 0 16px 6px rgba(248,113,113,.25), 0 0 32px rgba(248,113,113,.12); border-color: rgba(248,113,113,.45); }
    }
    @keyframes dotPulseRed {
      0%, 100% { opacity: 1; text-shadow: 0 0 0 rgba(248,113,113,0); }
      50% { opacity: .4; text-shadow: 0 0 12px rgba(248,113,113,1); }
    }
    .hero h1 { font-family: var(--font-serif); font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 700; line-height: 1.15; color: #fff; margin-bottom: 20px; max-width: 600px; }
    .hero h1 em { font-style: italic; color: #7FD1DE; }
    .hero__sub { font-size: 1.05rem; color: rgba(255,255,255,.8); line-height: 1.7; max-width: 500px; margin-bottom: 32px; }
    .hero__card { background: #fff; border-radius: var(--radius); padding: 28px 24px; width: 240px; flex-shrink: 0; box-shadow: var(--shadow-lg); }
    .hero__card-rating { display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px; }
    .hero__card-rating .score { font-family: var(--font-serif); font-size: 2.8rem; font-weight: 700; color: var(--teal); line-height: 1; }
    .hero__card-rating .max { font-size: 1rem; color: var(--gray); }
    .hero__stars { color: #F59E0B; font-size: 1.1rem; letter-spacing: 2px; margin-bottom: 6px; }
    .hero__card p { font-size: .82rem; color: var(--gray); line-height: 1.5; }
    .hero__card p strong { color: var(--dark); display: block; margin-top: 10px; font-size: .85rem; }
    .hero__divider { width: 100%; height: 1px; background: rgba(0,0,0,.08); margin: 14px 0; }
    .hero__card-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--teal-pale); color: var(--teal); border-radius: 50px; padding: 5px 12px; font-size: .75rem; font-weight: 600; }
    .trust-bar { background: var(--dark); padding: 14px 0; overflow: hidden; }
    .trust-bar__inner { display: flex; flex-wrap: nowrap; align-items: center; justify-content: center; gap: 0 24px; overflow-x: auto; scrollbar-width: none; }
    .trust-bar__inner::-webkit-scrollbar { display: none; }
    .trust-item { display: flex; align-items: center; gap: 6px; font-size: .8rem; color: rgba(255,255,255,.8); font-weight: 500; white-space: nowrap; flex-shrink: 0; }
    .trust-item__check { color: #4ADE80; font-weight: 700; }
    @media (max-width: 900px) { .trust-bar__inner { justify-content: flex-start; padding: 0 16px; } }
    .section { padding: 72px 0; }
    .section--white { background: #fff; }
    .section--teal { background: var(--teal); }
    .section--cream { background: var(--cream); }
    .section-label { display: inline-block; font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--orange); margin-bottom: 10px; }
    .section-label--light { color: rgba(255,255,255,.55); }
    .section-title { font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 700; color: var(--dark); line-height: 1.2; margin-bottom: 12px; }
    .section-title--light { color: #fff; }
    .section-sub { font-size: 1rem; color: var(--gray); max-width: 540px; line-height: 1.7; }
    .section-sub--light { color: rgba(255,255,255,.72); }
    .section-header { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 20px; margin-bottom: 48px; }
    .pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin: 40px 0; }
    .pain-card { display: flex; align-items: flex-start; gap: 14px; background: var(--cream); border: 1px solid var(--gray-light); border-radius: var(--radius); padding: 20px; transition: border-color .2s, box-shadow .2s; }
    .pain-card:hover { border-color: var(--teal-light); box-shadow: var(--shadow); }
    .pain-icon { width: 40px; height: 40px; border-radius: 10px; background: var(--teal-pale); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
    .pain-card strong { display: block; font-weight: 600; font-size: .95rem; color: var(--dark); margin-bottom: 3px; }
    .pain-card span { font-size: .83rem; color: var(--gray); }
    .pain-cta { text-align: center; margin-top: 8px; }
    .pain-note { display: block; margin-top: 12px; font-size: .83rem; color: var(--gray); }
    .usp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 48px; }
    .usp-card { display: flex; gap: 18px; align-items: flex-start; padding: 28px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); border-radius: var(--radius); transition: background .2s; }
    .usp-card:hover { background: rgba(255,255,255,.13); }
    .usp-icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(255,255,255,.15); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; flex-shrink: 0; }
    .usp-card strong { display: block; font-weight: 600; font-size: 1rem; color: #fff; margin-bottom: 6px; }
    .usp-card p { font-size: .875rem; color: rgba(255,255,255,.7); line-height: 1.6; margin: 0; }
    .diensten-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; }
    .dienst-card { display: flex; flex-direction: column; gap: 12px; background: #fff; border: 1px solid var(--gray-light); border-radius: var(--radius); padding: 28px 24px; transition: all .25s ease; }
    .dienst-card:hover { border-color: var(--teal-light); box-shadow: var(--shadow-lg); transform: translateY(-3px); }
    .dienst-icon { width: 52px; height: 52px; border-radius: 14px; background: var(--teal-pale); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .dienst-card h3 { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 600; color: var(--dark); }
    .dienst-card p { font-size: .875rem; color: var(--gray); line-height: 1.65; flex: 1; }
    .dienst-link { font-size: .83rem; font-weight: 600; color: var(--teal); margin-top: 4px; }
    .afspraak-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
    .afspraak-info h2 { font-family: var(--font-serif); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: var(--dark); margin-bottom: 16px; }
    .afspraak-info p { font-size: 1rem; color: var(--gray); line-height: 1.7; margin-bottom: 24px; }
    .afspraak-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
    .afspraak-list li { display: flex; align-items: center; gap: 10px; font-size: .9rem; color: var(--dark); }
    .afspraak-list li::before { content: '✓'; color: #4ADE80; background: var(--dark); width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .7rem; font-weight: 700; flex-shrink: 0; }
    .verne-widget { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow-lg); overflow: hidden; }
    .verne-widget iframe { width: 100%; min-height: 600px; border: none; display: block; }
    .callback-section { background: var(--teal-pale); border: 1px solid rgba(27,94,107,.12); border-radius: var(--radius); padding: 32px; margin-top: 32px; }
    .callback-section h3 { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 600; color: var(--dark); margin-bottom: 8px; }
    .callback-section p { font-size: .875rem; color: var(--gray); margin-bottom: 20px; }
    .callback-form { display: flex; gap: 12px; flex-wrap: wrap; }
    .callback-input { flex: 1; min-width: 180px; padding: 12px 16px; border: 1px solid var(--gray-light); border-radius: 50px; font-family: var(--font-sans); font-size: .9rem; color: var(--dark); background: #fff; outline: none; transition: border-color .2s; }
    .callback-input:focus { border-color: var(--teal); }
    .callback-success { display: none; padding: 14px 20px; background: #fff; border: 1px solid #4ADE80; border-radius: var(--radius); font-size: .9rem; color: var(--dark); }
    .reviews-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 32px; }
    .review-card { background: var(--cream); border: 1px solid var(--gray-light); border-radius: var(--radius); padding: 28px; position: relative; }
    .review-quote { position: absolute; top: 12px; left: 20px; font-family: var(--font-serif); font-size: 4rem; line-height: 1; color: var(--teal-pale); pointer-events: none; }
    .review-card p { font-size: .95rem; color: var(--dark); line-height: 1.7; margin: 16px 0 20px; }
    .review-meta { display: flex; align-items: center; gap: 10px; }
    .review-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--teal); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: .9rem; flex-shrink: 0; }
    .review-name { font-weight: 600; font-size: .875rem; }
    .review-source { font-size: .775rem; color: var(--gray); }
    .review-stars { color: #F59E0B; font-size: .85rem; }
    .reviews-aggregate { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 16px 32px; padding: 28px 32px; background: var(--teal-pale); border-radius: var(--radius); border: 1px solid rgba(27,94,107,.12); }
    .agg-score { font-family: var(--font-serif); font-size: 2.8rem; font-weight: 700; color: var(--teal); line-height: 1; }
    .agg-info strong { display: block; font-size: .9rem; font-weight: 600; }
    .agg-info span { font-size: .8rem; color: var(--gray); }
    .agg-stars { color: #F59E0B; font-size: .9rem; margin-top: 4px; }
    .agg-divider { width: 1px; height: 40px; background: var(--gray-light); }
    .team-photo { width: 100%; max-width: 720px; border-radius: var(--radius); margin: 32px auto 0; box-shadow: var(--shadow); }
    .team-grid { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-top: 32px; }
    .team-pill { display: flex; align-items: center; gap: 12px; background: #fff; border: 1px solid var(--gray-light); border-radius: 50px; padding: 10px 20px 10px 10px; transition: box-shadow .2s; }
    .team-pill:hover { box-shadow: var(--shadow); }
    .team-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--teal); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: .9rem; flex-shrink: 0; }
    .team-pill strong { display: block; font-size: .875rem; font-weight: 600; }
    .team-pill span { font-size: .775rem; color: var(--gray); }
    .midcta { text-align: center; padding: 80px 0; }
    .midcta h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 600; color: #fff; margin-bottom: 14px; max-width: 560px; margin-left: auto; margin-right: auto; }
    .midcta p { color: rgba(255,255,255,.75); font-size: 1rem; margin-bottom: 32px; }
    .hours-strip { display: flex; flex-wrap: wrap; gap: 16px 32px; justify-content: center; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); border-radius: var(--radius); padding: 24px 32px; margin-top: 40px; }
    .hours-item { text-align: center; }
    .hours-item strong { display: block; font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.55); margin-bottom: 4px; }
    .hours-item span { font-size: .88rem; color: #fff; font-weight: 500; }
    .blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 48px; }
    .blog-card { background: #fff; border: 1px solid var(--gray-light); border-radius: var(--radius); overflow: hidden; transition: box-shadow .2s, transform .2s; text-decoration: none; color: inherit; display: flex; flex-direction: column; }
    .blog-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
    .blog-img { height: 140px; background: var(--teal-pale); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
    .blog-body { padding: 22px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .blog-tag { font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--teal); }
    .blog-card h3 { font-family: var(--font-serif); font-size: 1.05rem; font-weight: 600; line-height: 1.35; color: var(--dark); }
    .blog-card p { font-size: .85rem; color: var(--gray); line-height: 1.6; flex: 1; }
    .blog-read-more { font-size: .83rem; font-weight: 600; color: var(--teal); margin-top: 4px; display: inline-block; }
    .blog-card:hover .blog-read-more { text-decoration: underline; }
    .footer { background: var(--dark); color: rgba(255,255,255,.7); padding: 56px 0 32px; }
    .footer__grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .footer__brand p { font-size: .875rem; line-height: 1.7; max-width: 280px; margin-top: 14px; }
    .footer__brand .nav__logo { color: #fff; }
    .footer__col h4 { font-size: .75rem; text-transform: uppercase; letter-spacing: .1em; font-weight: 600; color: rgba(255,255,255,.35); margin-bottom: 16px; }
    .footer__hours { list-style: none; }
    .footer__hours li { display: flex; justify-content: space-between; font-size: .875rem; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    .footer__hours li:last-child { border: none; }
    .footer__links { list-style: none; }
    .footer__links li { font-size: .875rem; padding: 5px 0; }
    .footer__links a { color: rgba(255,255,255,.7); transition: color .15s; }
    .footer__links a:hover { color: #fff; }
    .footer__bottom { border-top: 1px solid rgba(255,255,255,.08); padding-top: 24px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; font-size: .8rem; }
    .footer__legal { display: flex; gap: 20px; flex-wrap: wrap; }
    .footer__legal a { color: rgba(255,255,255,.35); transition: color .15s; }
    .footer__legal a:hover { color: rgba(255,255,255,.7); }
    .fab { position: fixed; bottom: 24px; right: 24px; z-index: 999; background: #25D366; color: #fff; width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; box-shadow: 0 4px 20px rgba(37,211,102,.4); transition: transform .2s, box-shadow .2s; cursor: pointer; text-decoration: none; }
    .fab:hover { transform: scale(1.1); box-shadow: 0 8px 28px rgba(37,211,102,.5); }
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity .6s ease, transform .6s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    @media (max-width: 900px) { .hero__inner { grid-template-columns: 1fr; } .hero__card { width: 100%; } .afspraak-grid { grid-template-columns: 1fr; } .footer__grid { grid-template-columns: 1fr; gap: 32px; } }
    @media (max-width: 600px) { .section { padding: 48px 0; } .reviews-aggregate { flex-direction: column; text-align: center; } .agg-divider { width: 48px; height: 1px; } }
  </style>
</head>
