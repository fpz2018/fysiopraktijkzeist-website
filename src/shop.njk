---
title: Shop — FysioFitness & Strippenkaarten | Fysiopraktijk Zeist
description: Abonnementen voor FysioFitness en strippenkaarten voor fysiotherapie. Direct online bestellen.
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,300&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal:#1B5E6B; --teal-light:#2A7F91; --teal-pale:#EBF5F7;
      --orange:#D96B2F; --orange-light:#F5834A; --cream:#F8F5EF;
      --dark:#1A2332; --gray:#5A6778; --gray-light:#E8E4DE;
      --radius:12px; --shadow:0 4px 24px rgba(27,94,107,.10);
      --shadow-lg:0 12px 48px rgba(27,94,107,.16);
      --font-serif:'Fraunces',Georgia,serif; --font-sans:'Inter',system-ui,sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-sans); background: var(--cream); color: var(--dark); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    .container { width: 100%; max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 50px; font-family: var(--font-sans); font-size: .95rem; font-weight: 600; cursor: pointer; border: 2px solid transparent; transition: all .2s ease; white-space: nowrap; text-decoration: none; }
    .btn-primary { background: var(--orange); color: #fff; border-color: var(--orange); }
    .btn-primary:hover { background: var(--orange-light); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(217,107,47,.35); color: #fff; }
    .btn-outline { background: transparent; color: var(--teal); border-color: var(--teal); }
    .btn-outline:hover { background: var(--teal); color: #fff; }
    .btn-ghost { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.2); }
    .btn-ghost:hover { background: rgba(255,255,255,.2); color: #fff; }
    /* Nav */
    .nav { position: sticky; top: 0; z-index: 100; background: rgba(248,245,239,.96); backdrop-filter: blur(12px); border-bottom: 1px solid var(--gray-light); }
    .nav__inner { display: flex; align-items: center; justify-content: space-between; height: 68px; }
    .nav__logo { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 700; color: var(--teal); line-height: 1.1; }
    .nav__logo span { display: block; font-size: .68rem; font-weight: 400; color: var(--gray); font-family: var(--font-sans); letter-spacing: .05em; text-transform: uppercase; }
    .nav__links { display: flex; gap: 4px; list-style: none; }
    .nav__links a { padding: 8px 14px; border-radius: 8px; font-size: .9rem; font-weight: 500; color: var(--dark); transition: background .15s, color .15s; }
    .nav__links a:hover, .nav__links a.active { background: var(--teal-pale); color: var(--teal); }
    .nav__actions { display: flex; align-items: center; gap: 8px; }
    .nav__hamburger { display: none; background: none; border: none; cursor: pointer; padding: 8px; flex-direction: column; gap: 5px; }
    .nav__hamburger span { display: block; width: 22px; height: 2px; background: var(--dark); border-radius: 2px; }
    .mobile-menu { display: none; position: fixed; inset: 0; top: 68px; background: var(--cream); z-index: 99; padding: 24px; flex-direction: column; gap: 8px; overflow-y: auto; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { padding: 14px 16px; border-radius: var(--radius); font-size: 1rem; font-weight: 500; color: var(--dark); border: 1px solid var(--gray-light); background: #fff; }
    @media (max-width: 768px) { .nav__links, .nav__actions .btn { display: none; } .nav__hamburger { display: flex; } }
    /* Shop hero */
    .shop-hero { background: var(--teal); padding: 56px 0 48px; }
    .shop-hero h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; color: #fff; margin-bottom: 12px; }
    .shop-hero p { font-size: 1.05rem; color: rgba(255,255,255,.8); max-width: 560px; line-height: 1.7; }
    .shop-breadcrumb { font-size: .8rem; color: rgba(255,255,255,.55); margin-bottom: 16px; }
    .shop-breadcrumb a { color: rgba(255,255,255,.55); }
    .shop-breadcrumb a:hover { color: #fff; }
    /* Secties */
    .shop-section { padding: 64px 0; }
    .shop-section:nth-child(even) { background: #fff; }
    .shop-section-header { margin-bottom: 40px; }
    .section-label { display: inline-block; font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--orange); margin-bottom: 8px; }
    .section-title { font-family: var(--font-serif); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: var(--dark); margin-bottom: 10px; }
    .section-sub { font-size: 1rem; color: var(--gray); max-width: 580px; line-height: 1.7; }
    /* Product grid */
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    .product-card { background: #fff; border: 2px solid var(--gray-light); border-radius: var(--radius); padding: 28px 24px; display: flex; flex-direction: column; gap: 16px; transition: box-shadow .2s, border-color .2s; position: relative; }
    .product-card:hover { box-shadow: var(--shadow-lg); border-color: var(--teal-light); }
    .product-card--highlight { border-color: var(--teal); background: #fff; }
    .product-card--highlight::before { content: 'Meest gekozen'; position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: var(--teal); color: #fff; font-size: .72rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; padding: 4px 14px; border-radius: 50px; white-space: nowrap; }
    .shop-section:nth-child(even) .product-card { background: var(--cream); }
    .shop-section:nth-child(even) .product-card--highlight { background: #fff; }
    .product-name { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 700; color: var(--dark); }
    .product-period { font-size: .8rem; color: var(--gray); font-weight: 500; text-transform: uppercase; letter-spacing: .06em; }
    .product-price { display: flex; align-items: baseline; gap: 4px; }
    .product-price .amount { font-family: var(--font-serif); font-size: 2.4rem; font-weight: 700; color: var(--teal); line-height: 1; }
    .product-price .currency { font-size: 1.1rem; font-weight: 600; color: var(--teal); align-self: flex-start; margin-top: 6px; }
    .product-price-note { font-size: .78rem; color: var(--gray); margin-top: -8px; }
    .product-features { list-style: none; display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .product-features li { font-size: .875rem; color: var(--dark); display: flex; align-items: flex-start; gap: 8px; }
    .product-features li::before { content: '✓'; color: #4ADE80; background: var(--dark); width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .6rem; font-weight: 700; flex-shrink: 0; margin-top: 2px; }
    .product-cta { margin-top: auto; }
    .btn-shop { width: 100%; justify-content: center; }
    .btn-disabled { background: var(--gray-light); color: var(--gray); border-color: var(--gray-light); cursor: not-allowed; }
    .btn-disabled:hover { transform: none; box-shadow: none; background: var(--gray-light); color: var(--gray); }
    /* Info blok */
    .shop-info { background: var(--teal); padding: 56px 0; }
    .shop-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .shop-info h2 { font-family: var(--font-serif); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: #fff; margin-bottom: 16px; }
    .shop-info p { color: rgba(255,255,255,.8); font-size: .95rem; line-height: 1.7; margin-bottom: 12px; }
    .shop-info-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin: 20px 0 28px; }
    .shop-info-features li { display: flex; align-items: center; gap: 10px; font-size: .9rem; color: rgba(255,255,255,.9); }
    .shop-info-features li::before { content: '✓'; color: #4ADE80; font-weight: 700; font-size: .85rem; }
    .shop-info-card { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15); border-radius: var(--radius); padding: 28px; }
    .shop-info-card h3 { font-family: var(--font-serif); font-size: 1.1rem; color: #fff; margin-bottom: 16px; }
    .shop-info-card p { font-size: .875rem; color: rgba(255,255,255,.75); line-height: 1.6; margin-bottom: 16px; }
    /* Footer */
    .footer { background: var(--dark); color: rgba(255,255,255,.7); padding: 56px 0 32px; }
    .footer__grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .footer__brand p { font-size: .875rem; line-height: 1.7; max-width: 280px; margin-top: 14px; }
    .footer__brand .nav__logo { color: #fff; }
    .footer__col h4 { font-size: .75rem; text-transform: uppercase; letter-spacing: .1em; font-weight: 600; color: rgba(255,255,255,.35); margin-bottom: 16px; }
    .footer__hours { list-style: none; }
    .footer__hours li { display: flex; justify-content: space-between; font-size: .875rem; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    .footer__hours li:last-child { border: none; }
    .footer__links { list-style: none; }
    .footer__links li { font-size: .875rem; padding: 5px 0; }
    .footer__links a { color: rgba(255,255,255,.7); transition: color .15s; }
    .footer__links a:hover { color: #fff; }
    .footer__bottom { border-top: 1px solid rgba(255,255,255,.08); padding-top: 24px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; font-size: .8rem; }
    .footer__legal { display: flex; gap: 20px; flex-wrap: wrap; }
    .footer__legal a { color: rgba(255,255,255,.35); transition: color .15s; }
    .footer__legal a:hover { color: rgba(255,255,255,.7); }
    .fab { position: fixed; bottom: 24px; right: 24px; z-index: 999; background: #25D366; color: #fff; width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; box-shadow: 0 4px 20px rgba(37,211,102,.4); transition: transform .2s, box-shadow .2s; text-decoration: none; }
    .fab:hover { transform: scale(1.1); box-shadow: 0 8px 28px rgba(37,211,102,.5); }
    @media (max-width: 900px) { .shop-info-grid { grid-template-columns: 1fr; } .footer__grid { grid-template-columns: 1fr; gap: 32px; } }
    @media (max-width: 600px) { .shop-section { padding: 40px 0; } .product-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

<!-- Nav -->
<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">
      {{ general.name }}
      <span>Fysiotherapeut zonder verwijzing</span>
    </a>
    <ul class="nav__links">
      <li><a href="/#behandelingen">Behandelingen</a></li>
      <li><a href="/#afspraak">Afspraak maken</a></li>
      <li><a href="/#team">Team</a></li>
      <li><a href="/#blog">Blog</a></li>
      <li><a href="/shop" class="active">Shop</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
    <div class="nav__actions">
      <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="padding:10px 18px;font-size:.85rem">💬 Afspraak maken</a>
    </div>
    <button class="nav__hamburger" id="menuBtn" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/#behandelingen" onclick="closeMobileMenu()">Behandelingen</a>
  <a href="/#afspraak" onclick="closeMobileMenu()">Afspraak maken</a>
  <a href="/#team" onclick="closeMobileMenu()">Team</a>
  <a href="/#blog" onclick="closeMobileMenu()">Blog</a>
  <a href="/shop" onclick="closeMobileMenu()">Shop</a>
  <a href="/#contact" onclick="closeMobileMenu()">Contact</a>
  <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="margin-top:8px">💬 WhatsApp afspraak</a>
  <a href="tel:{{ general.phone }}" class="btn btn-outline" style="margin-top:4px">📞 {{ general.phone }}</a>
</div>

<!-- Hero -->
<section class="shop-hero">
  <div class="container">
    <p class="shop-breadcrumb"><a href="/">Home</a> › Shop</p>
    <h1>FysioFitness &amp; Strippenkaarten</h1>
    <p>Beweeg en herstel op jouw tempo — onder begeleiding van onze therapeuten. Kies een abonnement of strippenkaart en betaal veilig online.</p>
  </div>
</section>

<!-- FysioFitness abonnementen -->
<section class="shop-section">
  <div class="container">
    <div class="shop-section-header">
      <span class="section-label">FysioFitness</span>
      <h2 class="section-title">{{ shop.fitness.title }}</h2>
      <p class="section-sub">{{ shop.fitness.intro }}</p>
    </div>
    <div class="product-grid">
      {% for product in shop.fitness.items %}
      <div class="product-card{% if product.highlight %} product-card--highlight{% endif %}">
        <div>
          <div class="product-period">{{ product.period }}</div>
          <div class="product-name">{{ product.name }}</div>
        </div>
        <div>
          <div class="product-price">
            <span class="currency">€</span>
            <span class="amount">{{ product.price }}</span>
          </div>
          <p class="product-price-note">{{ product.price_note }}</p>
        </div>
        <ul class="product-features">
          {% for feature in product.features %}
          <li>{{ feature }}</li>
          {% endfor %}
        </ul>
        <div class="product-cta">
          {% if product.mollie_url %}
            <a href="{{ product.mollie_url }}" class="btn btn-primary btn-shop" target="_blank" rel="noopener">Koop nu →</a>
          {% else %}
            <a href="tel:{{ general.phone }}" class="btn btn-outline btn-shop">📞 Bel voor aanmelding</a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Strippenkaarten -->
<section class="shop-section">
  <div class="container">
    <div class="shop-section-header">
      <span class="section-label">Fysiotherapie</span>
      <h2 class="section-title">{{ shop.strippenkaarten.title }}</h2>
      <p class="section-sub">{{ shop.strippenkaarten.intro }}</p>
    </div>
    <div class="product-grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); max-width: 700px;">
      {% for product in shop.strippenkaarten.items %}
      <div class="product-card{% if product.highlight %} product-card--highlight{% endif %}">
        <div class="product-name">{{ product.name }}</div>
        <div>
          <div class="product-price">
            <span class="currency">€</span>
            <span class="amount">{{ product.price }}</span>
          </div>
          <p class="product-price-note">{{ product.price_note }}</p>
        </div>
        <ul class="product-features">
          {% for feature in product.features %}
          <li>{{ feature }}</li>
          {% endfor %}
        </ul>
        <div class="product-cta">
          {% if product.mollie_url %}
            <a href="{{ product.mollie_url }}" class="btn btn-primary btn-shop" target="_blank" rel="noopener">Koop nu →</a>
          {% else %}
            <a href="tel:{{ general.phone }}" class="btn btn-outline btn-shop">📞 Bel voor aanmelding</a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Info blok -->
<section class="shop-info">
  <div class="container">
    <div class="shop-info-grid">
      <div>
        <h2>Veilig betalen,<br>direct starten</h2>
        <p>Na betaling ontvang je een bevestiging per e-mail. Voor abonnementen nemen wij contact op om je eerste les in te plannen.</p>
        <ul class="shop-info-features">
          <li>Betaal veilig via iDEAL, creditcard of Bancontact</li>
          <li>Abonnementen maandelijks opzegbaar (tenzij anders vermeld)</li>
          <li>Strippenkaarten 12 maanden geldig</li>
          <li>Factuur automatisch beschikbaar</li>
        </ul>
        <a href="tel:{{ general.phone }}" class="btn btn-ghost">📞 Vragen? Bel {{ general.phone }}</a>
      </div>
      <div class="shop-info-card">
        <h3>💬 Liever persoonlijk advies?</h3>
        <p>Niet zeker welk abonnement bij u past? Onze therapeuten helpen u graag bij het maken van de juiste keuze.</p>
        <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="width:100%;justify-content:center;margin-bottom:12px">WhatsApp ons</a>
        <a href="tel:{{ general.phone }}" style="display:block;text-align:center;font-size:.875rem;color:rgba(255,255,255,.7)">📞 {{ general.phone }}</a>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <div class="nav__logo">{{ general.name }}<span>Fysiotherapeut zonder verwijzing</span></div>
        <p>Wij behandelen de oorzaak van uw klacht — met persoonlijke aandacht en bewezen methoden. Al meer dan 35 jaar de fysiotherapiepraktijk van Zeist en omstreken.</p>
        <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap">
          <a href="https://wa.me/{{ general.whatsapp }}" class="btn btn-primary" style="padding:10px 18px;font-size:.85rem">💬 WhatsApp</a>
          <a href="tel:{{ general.phone }}" style="padding:10px 18px;font-size:.85rem;display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.2);border-radius:50px">📞 {{ general.phone }}</a>
        </div>
      </div>
      <div class="footer__col">
        <h4>Openingstijden</h4>
        <ul class="footer__hours">
          <li><span>Maandag</span><span>{{ hours.monday }}</span></li>
          <li><span>Dinsdag</span><span>{{ hours.tuesday }}</span></li>
          <li><span>Woensdag</span><span>{{ hours.wednesday }}</span></li>
          <li><span>Donderdag</span><span>{{ hours.thursday }}</span></li>
          <li><span>Vrijdag</span><span>{{ hours.friday }}</span></li>
          <li><span>Zat &amp; Zon</span><span>Gesloten</span></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Contact</h4>
        <ul class="footer__links">
          <li>{{ general.address }}</li>
          <li style="margin-top:10px"><a href="tel:{{ general.phone }}">📞 {{ general.phone }}</a></li>
          <li><a href="https://wa.me/{{ general.whatsapp }}">💬 WhatsApp</a></li>
          <li><a href="mailto:{{ general.email }}">✉ {{ general.email }}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2026 {{ general.name }} — BIG-geregistreerd · {{ general.review_score }}/10 op ZorgkaartNederland</span>
      <div class="footer__legal">
        <a href="/privacy">Privacy</a>
        <a href="/algemene-voorwaarden">Algemene voorwaarden</a>
        <a href="/tarieven">Tarieven 2026</a>
      </div>
    </div>
  </div>
</footer>

<a class="fab" href="https://wa.me/{{ general.whatsapp }}?text=Hallo%2C%20ik%20wil%20graag%20een%20afspraak%20maken" aria-label="WhatsApp">💬</a>

<script>
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('open'));
  function closeMobileMenu() { mobileMenu.classList.remove('open'); }
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on('init', user => {
      if (!user) { window.netlifyIdentity.on('login', () => { document.location.href = '/admin/'; }); }
    });
  }
</script>
</body>
</html>
